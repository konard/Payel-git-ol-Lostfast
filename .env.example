# --- Database -------------------------------------------------------------
# Leave DATABASE_URL unset to use the embedded PGlite database (zero-config).
# Set it to use a real PostgreSQL server (e.g. the one in docker-compose).
# DATABASE_URL=postgres://tradefast:tradefast@localhost:5432/tradefast

# Directory used by the embedded PGlite database when DATABASE_URL is unset.
# Use ':memory:' for an ephemeral database (used by the test suite).
TRADEFAST_DATA_DIR=.tradefast/pgdata

# --- Market data source ----------------------------------------------------
# Where OHLCV candles come from:
#   resilient (default) → live Binance, with deterministic synthetic fallback
#   live                → Binance only (fails if unreachable)
#   synthetic           → deterministic offline data (great for demos/CI/tests)
TRADEFAST_MARKET_SOURCE=resilient
# Public Binance REST endpoint. Override to use a mirror or a mock server.
TRADEFAST_MARKET_API=https://api.binance.com

# --- Analysis universe -----------------------------------------------------
# Comma-separated symbols, candle interval, history depth and account equity.
TRADEFAST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TRADEFAST_INTERVAL=1h
TRADEFAST_CANDLE_LIMIT=200
TRADEFAST_ACCOUNT_BALANCE=10000
# Trading style: long-term | medium-term | scalping (also switchable via /operating-mode)
TRADEFAST_MODE=medium-term

# --- Scraping (optional, Playwright/Chromium) ------------------------------
# Off by default so /start stays fast and offline. Set to 1 to scrape the top
# reference per symbol into the `scrapes` table (requires the Chromium binary).
TRADEFAST_SCRAPE=0

# --- News crawler (Playwright/Chromium) ------------------------------------
# /news crawls the configured market news and economic-calendar sources from
# src/config/news-sources.json. Override the JSON path for custom source sets.
# TRADEFAST_NEWS_SOURCES_FILE=./src/config/news-sources.json
TRADEFAST_NEWS_LIMIT=8
TRADEFAST_NEWS_DEPTH=2
TRADEFAST_NEWS_PAGE_LIMIT=8
TRADEFAST_NEWS_LINKS_PER_PAGE=6

# --- AI advisor (optional) -------------------------------------------------
# OpenAI-compatible endpoint (e.g. mlopass, Anthropic proxy, etc.)
# TRADEFAST_AI_API_URL=https://mlopass.env.pm/v1/chat/completions
# TRADEFAST_AI_API_KEY=
# Falls back to ANTHROPIC_API_KEY if TRADEFAST_AI_API_KEY is unset.
# When unset, a deterministic local heuristic advisor is used instead.
TRADEFAST_AI_MODEL=claude-4.7-opus
